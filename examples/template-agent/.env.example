# Model provider — this sample assumes the fleet default (Anthropic).
# If you override the model in agent.py to "openai:..." / "google-genai:..." /
# etc., swap this for the corresponding provider's API key.
ANTHROPIC_API_KEY=your-key-here

# LangSmith PAT
LANGSMITH_API_KEY=your-langsmith-api-key

# Workspace (LangSmith's "tenant" = workspace), org, and user IDs.
# Copy these three from fleet/config.json's "metadata" block.
LANGSMITH_TENANT_ID=        # → metadata.tenant_id
LANGSMITH_ORGANIZATION_ID=  # → metadata.organization_id
LANGSMITH_USER_ID=          # → metadata.ls_user_id  (required for any OAuth-backed tool)

# Builtin LangSmith tool server (Gmail, Calendar, builtin GitHub, etc.)
BUILTIN_MCP_URL=https://tools.langchain.com/mcp

# Optional: override the LangSmith host for self-hosted deployments
# LANGSMITH_HOST_URL=https://api.smith.langchain.com

# Optional: override the host-backend URL (OAuth broker, separate from smith)
# HOST_LANGCHAIN_API_URL=https://api.host.langchain.com

# Optional: how long (seconds) to cache built MCP components per worker process.
# LangGraph rebuilds the graph on every run, so caching avoids re-resolving MCP
# connections and re-fetching tools each time. The TTL also bounds OAuth-token
# staleness (tokens are baked into connection headers at build time). 0 disables
# caching (rebuild every run). Default: 600.
# FLEET_COMPONENTS_TTL=600

# Optional: enable the interactive OAuth consent flow (opens a browser and polls
# for authorization). Off by default so deployments and LangGraph Studio never
# open a browser or block. Set to 1 for a one-time local authorization via the
# CLI (`make run`); unprovisioned OAuth servers are otherwise skipped with a
# warning.
# FLEET_OAUTH_INTERACTIVE=1
